              90
            ]
          }
        },
        "tooltip": [
          {
            "field": "city"
          },
          {
            "field": "mean_rh_avg",
            "title": "Mean RH %",
            "format": ".1f"
          },
          {
            "field": "mean_solar_exposure_mj_m2",
            "title": "Solar exposure",
            "format": ".1f"
          },
          {
            "field": "overall_score",
            "title": "Balanced score",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/city_scores_overall.csv"
      },
      "transform": [
        {
          "filter": "datum.scenario == 'Balanced everyday comfort'"
        }
      ],
      "mark": {
        "type": "text",
