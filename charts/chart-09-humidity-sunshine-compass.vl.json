    },
    {
      "data": {
        "url": "data/city_scores_overall.csv"
      },
      "transform": [
        {
          "filter": "datum.scenario == 'Balanced everyday comfort'"
        }
      ],
      "mark": {
        "type": "circle",
        "stroke": "#fffdf8",
        "strokeWidth": 1.8,
        "opacity": 0.94
      },
      "params": [
        {
          "name": "hoverCity",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout",
            "fields": [
              "city"
            ]
          }
        }
      ],
      "encoding": {
        "x": {
          "field": "mean_rh_avg",
          "type": "quantitative"
        },
        "y": {
          "field": "mean_solar_exposure_mj_m2",
          "type": "quantitative"
        },
        "size": {
          "field": "overall_score",
          "type": "quantitative",
          "title": "Balanced score",
          "scale": {
            "domain": [
              53,
              95
            ],
            "range": [
              150,
              2800
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "titleLimit": 190,
            "symbolStrokeColor": "#26313b",
            "symbolStrokeWidth": 0.8
          }
        },
        "color": {
          "field": "rain_component",
          "type": "quantitative",
          "title": "Rain score",
          "scale": {
            "domain": [
              70,
              90
            ],
            "range": [
              "#d7ecf8",
              "#73b1d3",
              "#235f91"
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 240,
            "titleLimit": 160,
            "gradientThickness": 13
          }
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 0.86
          },
          "value": 0.2
        },
        "tooltip": [
          {
            "field": "city"
          },
          {
            "field": "mean_rh_avg",
            "title": "Mean relative humidity (%)",
            "format": ".1f"
          },
          {
            "field": "mean_solar_exposure_mj_m2",
            "title": "Mean daily solar exposure (MJ/m2)",
            "format": ".1f"
          },
          {
            "field": "rain_component",
            "title": "Rain comfort score",
            "format": ".1f"
          },
          {
            "field": "overall_score",
            "title": "Balanced score (0-100)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/city_scores_overall.csv"
      },
      "transform": [
        {
          "filter": "datum.scenario == 'Balanced everyday comfort'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 16,
        "fontWeight": 800,
        "color": "#1f2b32"
      },
      "encoding": {
        "x": {
          "field": "mean_rh_avg",
          "type": "quantitative"
        },
        "y": {
          "field": "mean_solar_exposure_mj_m2",
          "type": "quantitative"
        },
        "text": {
          "field": "city"
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 1
          },
          "value": 0.25
        }
      }
    }
  ],
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "gridColor": "#e8eeed",
      "domainColor": "#d2dad7",
      "tickColor": "#d2dad7",
      "labelFontSize": 14,
      "titleFontSize": 15,
      "gridOpacity": 0.72,
      "titleFontWeight": 800
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "labelFontSize": 14,
      "titleFontSize": 15,
      "titleFontWeight": 800
    },
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "background": "transparent",
    "header": {
      "labelFont": "Inter, Arial, sans-serif",
      "labelFontSize": 15,
      "labelFontWeight": 800,
      "labelColor": "#26313b",
      "titleFont": "Inter, Arial, sans-serif",
