        "fontWeight": 650,
        "color": "#26313b"
      },
      "encoding": {
        "x": {
          "field": "mean_rh_avg",
          "type": "quantitative"
        },
        "y": {
          "field": "mean_solar_exposure_mj_m2",
          "type": "quantitative"
        },
        "text": {
          "field": "city"
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 1
          },
          "value": 0.25
        }
      }
    }
