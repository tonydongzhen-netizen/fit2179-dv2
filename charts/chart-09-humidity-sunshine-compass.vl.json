      },
      "transform": [
        {
          "filter": "datum.scenario == 'Balanced everyday comfort'"
        }
      ],
      "mark": {
        "type": "circle",
        "stroke": "#26313b",
        "strokeWidth": 0.8,
        "opacity": 0.86
      },
      "params": [
        {
          "name": "hoverCity",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout",
            "fields": [
              "city"
            ]
          }
        }
      ],
      "encoding": {
        "x": {
          "field": "mean_rh_avg",
          "type": "quantitative"
        },
        "y": {
          "field": "mean_solar_exposure_mj_m2",
          "type": "quantitative"
        },
        "size": {
          "field": "overall_score",
          "type": "quantitative",
          "title": "Balanced score",
          "scale": {
            "domain": [
              60,
              90
            ],
            "range": [
              80,
              1250
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "titleLimit": 180
          }
        },
        "color": {
          "field": "rain_component",
          "type": "quantitative",
          "title": "Rain score",
          "scale": {
            "scheme": "blues",
            "domain": [
              70,
              90
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 220,
            "titleLimit": 160
          }
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 0.86
          },
          "value": 0.2
        },
        "tooltip": [
          {
            "field": "city"
          },
        {
          "field": "mean_rh_avg",
          "title": "Mean relative humidity (%)",
          "format": ".1f"
        },
        {
          "field": "mean_solar_exposure_mj_m2",
          "title": "Mean daily solar exposure (MJ/m2)",
          "format": ".1f"
        },
        {
          "field": "rain_component",
          "title": "Rain comfort score",
          "format": ".1f"
        },
        {
          "field": "overall_score",
          "title": "Balanced score (0-100)",
          "format": ".1f"
        }
        ]
      }
    },
    {
      "data": {
        "url": "data/city_scores_overall.csv"
      },
      "transform": [
        {
          "filter": "datum.scenario == 'Balanced everyday comfort'"
        }
      ],
      "mark": {
        "type": "text",
