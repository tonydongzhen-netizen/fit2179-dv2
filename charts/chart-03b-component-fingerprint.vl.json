{
  "description": "Component score fingerprint for the balanced everyday comfort scenario.",
  "width": "container",
  "height": 500,
  "background": "transparent",
  "data": {
    "url": "data/city_components_long.csv"
  },
  "transform": [
    {
      "filter": "datum.scenario == 'Balanced everyday comfort'"
    },
    {
      "calculate": "datum.component == 'day_temp_score' ? 'Day' : datum.component == 'night_temp_score' ? 'Sleep' : datum.component == 'heat_score' ? 'Heat' : datum.component == 'rain_score' ? 'Rain' : datum.component == 'humidity_score' ? 'Muggy' : datum.component == 'sunshine_score' ? 'Sun' : 'Stable'",
      "as": "component_axis_label"
    }
  ],
  "params": [
    {
      "name": "hoverCity",
      "select": {
        "type": "point",
        "on": "pointerover",
        "clear": "pointerout",
        "fields": [
          "city"
        ]
      }
    }
  ],
  "mark": {
    "type": "rect",
    "cornerRadius": 2
  },
  "encoding": {
    "y": {
      "field": "city",
      "type": "nominal",
      "sort": {
        "field": "rank",
        "order": "ascending"
      },
      "title": null,
      "axis": {
        "labelFontSize": 16
      }
    },
    "x": {
      "field": "component_axis_label",
      "type": "nominal",
      "sort": {
        "field": "component_order",
        "op": "min",
        "order": "ascending"
      },
      "title": null,
      "axis": {
        "labelAngle": -35,
        "labelLimit": 90,
        "labelFontSize": 16,
        "labelPadding": 8
      }
    },
    "color": {
      "field": "component_score",
      "type": "quantitative",
      "title": "Component score",
      "scale": {
        "scheme": "yellowgreenblue",
        "domain": [
          45,
          100
        ]
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "gradientLength": 190
      }
    },
    "opacity": {
      "condition": {
        "param": "hoverCity",
        "value": 1
      },
      "value": 0.35
    },
    "tooltip": [
      {
        "field": "city"
      },
      {
        "field": "component_label",
        "title": "Component"
      },
      {
        "field": "component_score",
        "title": "Component score (0-100)",
        "format": ".1f"
      }
    ]
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "gridColor": "#edf0f2",
      "domainColor": "#c9d0d6",
      "tickColor": "#c9d0d6",
      "labelFontSize": 15,
      "titleFontSize": 16
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "labelFontSize": 15,
      "titleFontSize": 16
    },
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "background": "transparent",
    "header": {
      "labelFont": "Inter, Arial, sans-serif",
      "labelFontSize": 16,
      "labelFontWeight": 750,
      "labelColor": "#26313b",
      "titleFont": "Inter, Arial, sans-serif",
      "titleFontSize": 16,
      "titleColor": "#26313b"
    }
  }
}
