{
  "description": "Component score fingerprint for the balanced everyday comfort scenario.",
  "width": 620,
  "height": 270,
  "data": {
    "url": "data/city_components_long.csv"
  },
  "transform": [
    {
      "filter": "datum.scenario == 'Balanced everyday comfort'"
    }
  ],
  "mark": {
    "type": "rect",
    "cornerRadius": 2
  },
  "encoding": {
    "y": {
      "field": "city",
      "type": "nominal",
      "sort": {
        "field": "rank",
        "order": "ascending"
      },
      "title": null,
      "axis": {
        "labelFontSize": 12
      }
    },
    "x": {
      "field": "component_short",
      "type": "nominal",
      "sort": {
        "field": "component_order",
        "op": "min",
        "order": "ascending"
      },
      "title": null,
      "axis": {
        "labelAngle": -30,
        "labelLimit": 92,
        "labelFontSize": 10
      }
    },
    "color": {
      "field": "component_score",
      "type": "quantitative",
      "title": "Component score",
      "scale": {
        "scheme": "yellowgreenblue",
        "domain": [
          45,
          100
        ]
      }
    },
    "tooltip": [
      {
        "field": "city"
      },
      {
        "field": "component_label",
        "title": "Component"
      },
      {
        "field": "component_score",
        "title": "Score",
        "format": ".1f"
      }
    ]
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "gridColor": "#edf0f2",
      "domainColor": "#c9d0d6",
      "tickColor": "#c9d0d6"
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b"
    },
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "background": "#ffffff"
  }
}
