{
  "description": "Rain rhythm barcode showing monthly rain days and rainfall intensity.",
  "title": {
    "text": "Rain days per month",
    "anchor": "start",
    "font": "Inter, Arial, sans-serif",
    "fontSize": 19,
    "fontWeight": 800,
    "color": "#26313b",
    "offset": 10
  },
  "data": {
    "url": "data/city_scores_monthly.csv"
  },
  "params": [
    {
      "name": "hoverMonth",
      "select": {
        "type": "point",
        "on": "pointerover",
        "clear": "pointerout",
        "fields": [
          "month_num"
        ]
      }
    }
  ],
  "facet": {
    "field": "city",
    "type": "nominal",
    "sort": [
      "Sydney",
      "Brisbane",
      "Adelaide",
      "Perth",
      "Melbourne",
      "Hobart",
      "Canberra",
      "Darwin"
    ],
    "title": null
  },
  "columns": 1,
  "spec": {
    "width": "container",
    "height": 128,
    "mark": {
      "type": "bar",
      "cornerRadiusEnd": 2
    },
    "encoding": {
      "x": {
        "field": "month_num",
        "type": "ordinal",
        "title": "Month",
        "axis": {
          "values": [
            1,
            3,
            5,
            7,
            9,
            11
          ],
          "labelExpr": "['Jan','Mar','May','Jul','Sep','Nov'][indexof([1,3,5,7,9,11], datum.value)]",
          "labelFontSize": 15
        }
      },
      "y": {
        "field": "rain_days",
        "type": "quantitative",
        "title": "Rain days",
        "scale": {
          "domain": [
            0,
            23
          ]
        },
        "axis": {
          "values": [
            0,
            10,
            20
          ],
          "labelFontSize": 16,
          "labelPadding": 6,
          "tickSize": 5
        }
      },
      "color": {
        "field": "mean_rain_mm",
        "type": "quantitative",
        "title": "Monthly rainfall (mm)",
        "scale": {
          "scheme": "blues"
        },
        "legend": {
          "orient": "bottom",
          "direction": "horizontal",
          "gradientLength": 220,
          "gradientThickness": 12,
          "titleLimit": 260
        }
      },
      "opacity": {
        "condition": {
          "param": "hoverMonth",
          "value": 1
        },
        "value": 0.35
      },
      "tooltip": [
        {
          "field": "city"
        },
        {
          "field": "month"
        },
        {
          "field": "rain_days",
          "title": "Rain days in month"
        },
        {
          "field": "mean_rain_mm",
          "title": "Monthly rainfall (mm)"
        },
        {
          "field": "rain_days_ge_1mm",
          "title": "Wet days (>=1 mm)"
        }
      ]
    }
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "gridColor": "#edf0f2",
      "domainColor": "#c9d0d6",
      "tickColor": "#c9d0d6",
      "labelFontSize": 15,
      "titleFontSize": 16
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "labelFontSize": 15,
      "titleFontSize": 16
    },
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "background": "transparent",
    "header": {
      "labelFont": "Inter, Arial, sans-serif",
      "labelFontSize": 16,
      "labelFontWeight": 750,
      "labelColor": "#26313b",
      "titleFont": "Inter, Arial, sans-serif",
      "titleFontSize": 16,
      "titleColor": "#26313b"
    }
  },
  "background": "transparent"
}
