{
  "description": "Balanced everyday comfort ranking for Australian capital cities.",
  "width": "container",
  "height": 400,
  "background": "transparent",
  "padding": {
    "left": 82,
    "right": 38,
    "top": 12,
    "bottom": 46
  },
  "data": {
    "url": "data/city_scores_overall.csv"
  },
  "transform": [
    {
      "filter": "datum.scenario == 'Balanced everyday comfort'"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4,
        "height": {
          "band": 0.62
        },
        "color": "#edf2ef",
        "opacity": 0.88
      },
      "encoding": {
        "x": {
          "field": "track_score",
          "type": "quantitative",
          "title": "Balanced comfort score (0-100)",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": null
        },
        "tooltip": null
      },
      "transform": [
        {
          "calculate": "100",
          "as": "track_score"
        }
      ]
    },
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 5,
        "height": {
          "band": 0.62
        }
      },
      "params": [
        {
          "name": "hoverCity",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout",
            "fields": [
              "city"
            ]
          }
        }
      ],
      "encoding": {
        "x": {
          "field": "overall_score",
          "type": "quantitative",
          "title": "Balanced comfort score (0-100)",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": {
            "tickCount": 6,
            "labelFontSize": 14,
            "titleFontSize": 15
          }
        },
        "color": {
          "condition": [
            {
              "test": "datum.rank == 1",
              "value": "#1f766f"
            },
            {
              "test": "datum.rank <= 4",
              "value": "#7fa39f"
            }
          ],
          "value": "#9fb1b7"
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 1
          },
          "value": 0.35
        },
        "tooltip": [
          {
            "field": "city"
          },
          {
            "field": "rank"
          },
          {
            "field": "overall_score",
            "title": "Balanced score (0-100)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 9,
        "fontSize": 16,
        "fontWeight": 800,
        "color": "#26313b"
      },
      "encoding": {
        "x": {
          "field": "overall_score",
          "type": "quantitative"
        },
        "text": {
          "field": "overall_score",
          "format": ".1f"
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 1
          },
          "value": 0.35
        }
      }
    }
  ],
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "gridColor": "#e8eeed",
      "domainColor": "#d2dad7",
      "tickColor": "#d2dad7",
      "labelFontSize": 14,
      "titleFontSize": 15,
      "gridOpacity": 0.72,
      "titleFontWeight": 800
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "labelFontSize": 14,
      "titleFontSize": 15,
      "titleFontWeight": 800
    },
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "background": "transparent",
    "header": {
      "labelFont": "Inter, Arial, sans-serif",
      "labelFontSize": 15,
      "labelFontWeight": 800,
      "labelColor": "#26313b",
      "titleFont": "Inter, Arial, sans-serif",
      "titleFontSize": 15,
      "titleColor": "#26313b"
    }
  },
  "encoding": {
    "y": {
      "field": "city",
      "type": "nominal",
      "sort": {
        "field": "rank",
        "op": "min",
        "order": "ascending"
      },
      "title": null,
      "axis": {
        "labelFontSize": 14,
        "labelPadding": 8,
        "labelColor": "#202932"
      }
    }
  }
}
