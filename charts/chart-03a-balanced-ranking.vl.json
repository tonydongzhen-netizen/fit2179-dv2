{
  "description": "Balanced everyday comfort ranking for Australian capital cities.",
  "width": "container",
  "height": 470,
  "background": "transparent",
  "padding": {
    "left": 82,
    "right": 38,
    "top": 12,
    "bottom": 46
  },
  "data": {
    "url": "data/city_scores_overall.csv"
  },
  "transform": [
    {
      "filter": "datum.scenario == 'Balanced everyday comfort'"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4,
        "height": {
          "band": 0.56
        }
      },
      "params": [
        {
          "name": "hoverCity",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout",
            "fields": [
              "city"
            ]
          }
        }
      ],
      "encoding": {
        "y": {
          "field": "city",
          "type": "nominal",
          "sort": {
            "field": "rank",
            "order": "ascending"
          },
          "title": null,
          "axis": {
            "labelFontSize": 17,
            "labelPadding": 8,
            "labelColor": "#202932"
          }
        },
        "x": {
          "field": "overall_score",
          "type": "quantitative",
          "title": "Balanced comfort score (0-100)",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": {
            "tickCount": 6,
            "labelFontSize": 15,
            "titleFontSize": 16
          }
        },
        "color": {
          "condition": [
            {
              "test": "datum.rank == 1",
              "value": "#1f766f"
            },
            {
              "test": "datum.rank <= 4",
              "value": "#7fa39f"
            }
          ],
          "value": "#9fb1b7"
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 1
          },
          "value": 0.35
        },
        "tooltip": [
          {
            "field": "city"
          },
          {
            "field": "rank"
          },
          {
            "field": "overall_score",
            "title": "Balanced score (0-100)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 7,
        "fontSize": 17,
        "fontWeight": 700,
        "color": "#26313b"
      },
      "encoding": {
        "y": {
          "field": "city",
          "type": "nominal",
          "sort": {
            "field": "rank",
            "order": "ascending"
          }
        },
        "x": {
          "field": "overall_score",
          "type": "quantitative"
        },
        "text": {
          "field": "overall_score",
          "format": ".1f"
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 1
          },
          "value": 0.35
        }
      }
    }
  ],
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "gridColor": "#edf0f2",
      "domainColor": "#c9d0d6",
      "tickColor": "#c9d0d6",
      "labelFontSize": 15,
      "titleFontSize": 16
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "labelFontSize": 15,
      "titleFontSize": 16
    },
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "background": "transparent",
    "header": {
      "labelFont": "Inter, Arial, sans-serif",
      "labelFontSize": 16,
      "labelFontWeight": 750,
      "labelColor": "#26313b",
      "titleFont": "Inter, Arial, sans-serif",
      "titleFontSize": 16,
      "titleColor": "#26313b"
    }
  }
}
