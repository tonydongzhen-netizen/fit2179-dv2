{
  "description": "Australia capital climate comfort map with direct labels for each city.",
  "width": 620,
  "height": 460,
  "background": "transparent",
  "padding": {
    "left": 0,
    "top": 4,
    "right": 4,
    "bottom": 4
  },
  "projection": {
    "type": "mercator",
    "center": [
      134.5,
      -28
    ],
    "scale": 710,
    "translate": [
      292,
      222
    ]
  },
  "layer": [
    {
      "data": {
        "url": "data/australia_context_outline.geojson"
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eef4f0",
        "stroke": "#bcc9cc",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "data/city_locations.geojson",
        "format": {
          "property": "features"
        }
      },
      "transform": [
        {
          "calculate": "datum.properties.city",
          "as": "city"
        },
        {
          "calculate": "datum.properties.state_or_territory",
          "as": "state"
        },
        {
          "calculate": "datum.properties.balanced_score",
          "as": "balanced_score"
        },
        {
          "calculate": "datum.properties.balanced_rank",
          "as": "rank"
        },
        {
          "calculate": "datum.properties.population_2025",
          "as": "population"
        },
        {
          "calculate": "datum.geometry.coordinates[0]",
          "as": "lon"
        },
        {
          "calculate": "datum.geometry.coordinates[1]",
          "as": "lat"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 340,
        "stroke": "#fffdf8",
        "strokeWidth": 1.6,
        "opacity": 0.94
      },
      "params": [
        {
          "name": "hoverCity",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout",
            "fields": [
              "city"
            ]
          }
        }
      ],
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "color": {
          "field": "balanced_score",
          "type": "quantitative",
          "title": "Balanced score",
          "scale": {
            "scheme": "tealblues",
            "domain": [
              60,
              90
            ]
          },
          "legend": {
            "orient": "right",
            "gradientLength": 170,
            "gradientThickness": 14,
            "titleLimit": 170,
            "labelFontSize": 14,
            "titleFontSize": 15
          }
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 0.88
          },
          "value": 0.2
        },
        "tooltip": [
          {
            "field": "city",
            "title": "City"
          },
          {
            "field": "state",
            "title": "State"
          },
          {
            "field": "rank",
            "title": "Balanced rank"
          },
          {
            "field": "balanced_score",
            "title": "Balanced score (0-100)",
            "format": ".1f"
          },
          {
            "field": "population",
            "title": "ABS population 2025",
            "format": ","
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/city_locations.geojson",
        "format": {
          "property": "features"
        }
      },
      "transform": [
        {
          "calculate": "datum.properties.city",
          "as": "city"
        },
        {
          "calculate": "datum.properties.state_or_territory",
          "as": "state"
        },
        {
          "calculate": "datum.properties.balanced_score",
          "as": "balanced_score"
        },
        {
          "calculate": "datum.properties.balanced_rank",
          "as": "rank"
        },
        {
          "calculate": "datum.properties.population_2025",
          "as": "population"
        },
        {
          "calculate": "datum.geometry.coordinates[0]",
          "as": "lon"
        },
        {
          "calculate": "datum.geometry.coordinates[1]",
          "as": "lat"
        },
        {
          "filter": "datum.rank == 1"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 760,
        "fillOpacity": 0,
        "stroke": "#1f766f",
        "strokeWidth": 3.2
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "city",
            "title": "City"
          },
          {
            "field": "state",
            "title": "State"
          },
          {
            "field": "rank",
            "title": "Balanced rank"
          },
          {
            "field": "balanced_score",
            "title": "Balanced score (0-100)",
            "format": ".1f"
          },
          {
            "field": "population",
            "title": "ABS population 2025",
            "format": ","
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/city_locations.geojson",
        "format": {
          "property": "features"
        }
      },
      "transform": [
        {
          "calculate": "datum.properties.city",
          "as": "city"
        },
        {
          "calculate": "datum.geometry.coordinates[0]",
          "as": "lon"
        },
        {
          "calculate": "datum.geometry.coordinates[1]",
          "as": "lat"
        },
        {
          "calculate": "datum.properties.city == 'Darwin' ? 131.4 : datum.properties.city == 'Perth' ? 116.9 : datum.properties.city == 'Adelaide' ? 139.8 : datum.properties.city == 'Brisbane' ? 154.0 : datum.properties.city == 'Sydney' ? 153.5 : datum.properties.city == 'Canberra' ? 151.2 : datum.properties.city == 'Melbourne' ? 144.6 : datum.properties.city == 'Hobart' ? 148.1 : datum.geometry.coordinates[0]",
          "as": "label_lon"
        },
        {
          "calculate": "datum.properties.city == 'Darwin' ? -12.0 : datum.properties.city == 'Perth' ? -30.6 : datum.properties.city == 'Adelaide' ? -33.6 : datum.properties.city == 'Brisbane' ? -26.0 : datum.properties.city == 'Sydney' ? -32.7 : datum.properties.city == 'Canberra' ? -36.3 : datum.properties.city == 'Melbourne' ? -39.2 : datum.properties.city == 'Hobart' ? -43.3 : datum.geometry.coordinates[1]",
          "as": "label_lat"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Inter, Arial, sans-serif",
        "fontSize": 16,
        "fontWeight": 800,
        "fill": "#1f2b32",
        "align": "left",
        "baseline": "middle"
      },
      "encoding": {
        "longitude": {
          "field": "label_lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "label_lat",
          "type": "quantitative"
        },
        "text": {
          "field": "city"
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 1
          },
          "value": 0.25
        }
      }
    }
  ],
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "gridColor": "#e8eeed",
      "domainColor": "#d2dad7",
      "tickColor": "#d2dad7",
      "labelFontSize": 14,
      "titleFontSize": 15,
      "gridOpacity": 0.72,
      "titleFontWeight": 800
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "labelFontSize": 14,
      "titleFontSize": 15,
      "titleFontWeight": 800
    },
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "background": "transparent",
    "header": {
      "labelFont": "Inter, Arial, sans-serif",
      "labelFontSize": 15,
      "labelFontWeight": 800,
      "labelColor": "#26313b",
      "titleFont": "Inter, Arial, sans-serif",
      "titleFontSize": 15,
      "titleColor": "#26313b"
    }
  }
}
