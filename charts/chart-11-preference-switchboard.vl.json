{
  "description": "Preference sensitivity switchboard comparing ranks across scenarios.",
  "width": "container",
  "height": 450,
  "background": "transparent",
  "data": {
    "url": "data/city_scores_overall.csv"
  },
  "transform": [
    {
      "calculate": "datum.rank_change_from_balanced > 0 ? '+' + datum.rank_change_from_balanced : datum.rank_change_from_balanced < 0 ? '' + datum.rank_change_from_balanced : '0'",
      "as": "change_label"
    },
    {
      "calculate": "datum.rank_arrow == 'up' ? 'Rank improves' : datum.rank_arrow == 'down' ? 'Rank drops' : 'Rank unchanged'",
      "as": "change_tooltip"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rect",
        "cornerRadius": 5,
        "stroke": "#fffdf8",
        "strokeWidth": 1.1
      },
      "params": [
        {
          "name": "hoverCity",
          "select": {
            "type": "point",
            "on": "pointerover",
            "clear": "pointerout",
            "fields": [
              "city"
            ]
          }
        }
      ],
      "encoding": {
        "x": {
          "field": "city",
          "type": "nominal",
          "sort": [
            "Sydney",
            "Brisbane",
            "Adelaide",
            "Perth",
            "Melbourne",
            "Hobart",
            "Canberra",
            "Darwin"
          ],
          "title": null,
          "axis": {
            "labelAngle": -90,
            "labelFontSize": 14
          }
        },
        "y": {
          "field": "scenario",
          "type": "nominal",
          "sort": [
            "Balanced everyday comfort",
            "Avoid hot days",
            "Sleep cool at night",
            "Stay dry",
            "Enjoy sunshine",
            "Stable all year",
            "Avoid muggy heat"
          ],
          "title": null,
          "axis": {
            "labelExpr": "datum.label == 'Balanced everyday comfort' ? 'Balanced' : datum.label == 'Sleep cool at night' ? 'Cool nights' : datum.label == 'Enjoy sunshine' ? 'Sunshine' : datum.label == 'Stable all year' ? 'Stable year' : datum.label == 'Avoid muggy heat' ? 'Avoid muggy' : datum.label",
            "labelLimit": 130,
            "labelFontSize": 14
          }
        },
        "color": {
          "field": "overall_score",
          "type": "quantitative",
          "title": "Scenario score (0-100)",
          "scale": {
            "domain": [
              50,
              95
            ],
            "range": [
              "#bde5dc",
              "#4aa5ba",
              "#1e5d85"
            ]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 200,
            "titleLimit": 220,
            "gradientThickness": 13
          }
        },
        "stroke": {
          "condition": {
            "test": "datum.rank == 1",
            "value": "#26313b"
          },
          "value": "#fffdf8"
        },
        "strokeWidth": {
          "condition": {
            "test": "datum.rank == 1",
            "value": 1.8
          },
          "value": 0.9
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 1
          },
          "value": 0.55
        },
        "tooltip": [
          {
            "field": "scenario",
            "title": "Preference scenario"
          },
          {
            "field": "city",
            "title": "City"
          },
          {
            "field": "rank",
            "title": "Rank in scenario"
          },
          {
            "field": "overall_score",
            "title": "Scenario score (0-100)",
            "format": ".1f"
          },
          {
            "field": "rank_change_from_balanced",
            "title": "Rank change from balanced"
          },
          {
            "field": "change_tooltip",
            "title": "Movement"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -9,
        "fontSize": 18,
        "fontWeight": 800,
        "color": "#ffffff",
        "stroke": "#17313a",
        "strokeWidth": 0.25,
        "strokeOpacity": 0.55
      },
      "encoding": {
        "x": {
          "field": "city",
          "type": "nominal",
          "sort": [
            "Sydney",
            "Brisbane",
            "Adelaide",
            "Perth",
            "Melbourne",
            "Hobart",
            "Canberra",
            "Darwin"
          ]
        },
        "y": {
          "field": "scenario",
          "type": "nominal",
          "sort": [
            "Balanced everyday comfort",
            "Avoid hot days",
            "Sleep cool at night",
            "Stay dry",
            "Enjoy sunshine",
            "Stable all year",
            "Avoid muggy heat"
          ]
        },
        "text": {
          "field": "rank"
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 1
          },
          "value": 0.65
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": 17,
        "fontSize": 15,
        "fontWeight": 800,
        "stroke": "#17313a",
        "strokeWidth": 0.25,
        "strokeOpacity": 0.65
      },
      "encoding": {
        "x": {
          "field": "city",
          "type": "nominal",
          "sort": [
            "Sydney",
            "Brisbane",
            "Adelaide",
            "Perth",
            "Melbourne",
            "Hobart",
            "Canberra",
            "Darwin"
          ]
        },
        "y": {
          "field": "scenario",
          "type": "nominal",
          "sort": [
            "Balanced everyday comfort",
            "Avoid hot days",
            "Sleep cool at night",
            "Stay dry",
            "Enjoy sunshine",
            "Stable all year",
            "Avoid muggy heat"
          ]
        },
        "text": {
          "field": "change_label"
        },
        "color": {
          "condition": [
            {
              "test": "datum.rank_arrow == 'up'",
              "value": "#d7f5e7"
            },
            {
              "test": "datum.rank_arrow == 'down'",
              "value": "#ffe1d6"
            }
          ],
          "value": "#f7fbfb"
        },
        "opacity": {
          "condition": {
            "param": "hoverCity",
            "value": 1
          },
          "value": 0.65
        }
      }
    }
  ],
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "gridColor": "#e8eeed",
      "domainColor": "#d2dad7",
      "tickColor": "#d2dad7",
      "labelFontSize": 14,
      "titleFontSize": 15,
      "gridOpacity": 0.72,
      "titleFontWeight": 800
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#4c5965",
      "titleColor": "#26313b",
      "labelFontSize": 14,
      "titleFontSize": 15,
      "titleFontWeight": 800
    },
    "view": {
      "stroke": null
    },
    "font": "Inter, Arial, sans-serif",
    "background": "transparent",
    "header": {
      "labelFont": "Inter, Arial, sans-serif",
      "labelFontSize": 15,
      "labelFontWeight": 800,
      "labelColor": "#26313b",
      "titleFont": "Inter, Arial, sans-serif",
      "titleFontSize": 15,
      "titleColor": "#26313b"
    }
  }
}
